{
  "name": "tesuto",
  "displayName": "Tesuto",
  "description": "Explore and test your APIs without leaving VS Code",
  "version": "0.1.0",
  "publisher": "SunnySinha",
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sunny-2610/Tesuto"
  },
  "categories": ["Other"],
  "keywords": ["api", "rest", "http", "client", "tester"],
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension/extension.js",
  "activationEvents": [
    "onView:tesuto-sidebar-view"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tesuto.open",
        "title": "Open Tesuto"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tesuto-sidebar",
          "title": "Tesuto",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "tesuto-sidebar": [
        {
          "type": "webview",
          "id": "tesuto-sidebar-view",
          "name": "Tesuto"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js && vite build",
    "watch": "tsc-watch --onSuccess \"tsc-alias\"",
    "build:webview": "vite build",
    "dev": "npm run compile && code --extensionDevelopmentPath=."
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.25.0",
    "tsc-alias": "^1.8.16",
    "tsc-watch": "^6.2.1",
    "typescript": "^5.3.0",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  }
}