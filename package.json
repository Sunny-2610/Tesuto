{
  "name": "tesuto",
  "displayName": "Tesuto",
  "description": "Explore and test your APIs without leaving VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension/extension.js",
  "activationEvents": [
    "onView:tesuto-sidebar-view"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tesuto.open",
        "title": "Open Tesuto"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tesuto-sidebar",
          "title": "Tesuto",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "tesuto-sidebar": [
        {
          "type": "webview",
          "id": "tesuto-sidebar-view",
          "name": "Tesuto"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && vite build",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.3.0",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
