{
  "compilerOptions": {

    "target": "ES2020",

    "module": "commonjs",

    "lib": [
      "ES2020",
      "DOM"
    ],

    "jsx": "react-jsx",

    "moduleResolution": "node",

    "rootDir": "src",

    "outDir": "out",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "sourceMap": true,

    "types": ["node"],

    "baseUrl": "./src",

    "paths": {
      "@shared/*": [
        "shared/*"
      ],

      "@webview/*": [
        "webview/*"
      ],

      "@extension/*": [
        "extension/*"
      ]
    }
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src/test"
  ]
}