{
  "compilerOptions": {
    "jsx": "react",

    "target": "ES2020",

    "lib": ["ES2020", "DOM"],

    "module": "commonjs",

    "moduleResolution": "node",

    "outDir": "out",

    "rootDir": "src",

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "types": ["node"],

    "baseUrl": "./src",

    "paths": {
      "@shared/*": ["shared/*"],
      "@webview/*": ["webview/*"],
      "@extension/*": ["extension/*"]
    }
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "out",
    "dist",
    "src/test"
  ]
}